{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "model": "google/gemini-2.0-flash",
  "small_model": "google/gemini-2.0-flash-preview-06-05",
  "provider": {
    "google": {
      "models": {
        "gemini-2.0-flash": {
          "supports": {
            "tools": true,
            "systemInstructions": true,
            "images": true
          }
        },
        "gemini-2.5-pro-preview": {
          "supports": {
            "tools": true,
            "systemInstructions": true,
            "images": true
          }
        },
        "gemini-3.0-flash": {
          "supports": {
            "tools": true,
            "systemInstructions": true,
            "images": true
          }
        },
        "gemini-3.0-pro": {
          "supports": {
            "tools": true,
            "systemInstructions": true,
            "images": true
          }
        }
      },
      "options": {
        "projectId": "{env:GOOGLE_PROJECT_ID}"
      }
    }
  }
}
